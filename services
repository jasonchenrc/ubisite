0a7bcd799afefcc88f_nyu_parallax_section_1-20-1-20-2-.jpeg" alt="" style="opacity:0" sizes="(max-width: 2880px) 100vw, 2880px" data-w-id="932fd715-a2f0-4b1c-b709-9f267c8d4907" loading="eager" srcset="images/6541597bf1840c0523726a12_643f0b0a7bcd799afefcc88f_nyu_parallax_section_1-20-1-20-2-p-500.jpeg 500w, images/6541597bf1840c0523726a12_643f0b0a7bcd799afefcc88f_nyu_parallax_section_1-20-1-20-2-p-800.jpeg 800w, images/6541597bf1840c0523726a12_643f0b0a7bcd799afefcc88f_nyu_parallax_section_1-20-1-20-2-p-1080.jpeg 1080w, images/6541597bf1840c0523726a12_643f0b0a7bcd799afefcc88f_nyu_parallax_section_1-20-1-20-2-p-1600.jpeg 1600w, images/6541597bf1840c0523726a12_643f0b0a7bcd799afefcc88f_nyu_parallax_section_1-20-1-20-2-p-2000.jpeg 2000w, images/6541597bf1840c0523726a12_643f0b0a7bcd799afefcc88f_nyu_parallax_section_1-20-1-20-2-.jpeg 2880w"/></div></div></div></div></div></header><section class="section-client-logos"><div class="padding-global"></div></section><div class="section-services"><section class="services-component-wrapper"><div class="padding-global is-2rem"><div class="container-large"><div class="section-padding-large"><div class="margin-bottom margin-large"><div class="max-width-large"><div data-w-id="e8b655bf-6ea0-b9ea-c366-c6c69774825c" style="opacity:0" class="tagline-pill"><div>What we do</div></div><div class="margin-bottom margin-small"><h2 data-w-id="01085c0b-d7b5-7af3-3381-35bfbb69aed6" style="opacity:0" class="heading-style-h2 weight-medium">Our Services</h2></div></div></div><div class="services-component"><div class="w-dyn-list"><div role="list" class="services-list w-dyn-items"><div role="listitem" class="service-accordion w-dyn-item"><div class="service-name"><div class="text-size-large weight-medium">Find the right people, everywhere.</div></div><div class="service-description"><div class="w-layout-grid service-component"><div class="service-image-wrapper"><img src="images/copy-20of-20untitled-20design-20-2-.png" loading="lazy" alt="" class="service-image"/></div><div blocks-name="layout1_content" blocks-slot-children="ST265" id="w-node-_8a309907-dd41-8676-e504-528cd7993c04-b8105c8b" class="service-content"><div class="margin-bottom margin-small"><h2 blocks-name="heading" class="heading-style-h3">PARTICIPANT RECRUITMENT</h2></div><div class="w-richtext"><p><strong>We don&#x27;t fill quotas—we find fits.</strong></p><p>Great participants are engaged, articulate, and insightful. Our double-screened, purpose-built approach ensures you get the right people, every time.</p><p>‍</p><p><strong>Transparency. Quality. Results.</strong></p><ul role="list"><li>Custom screeners aligned to your research objectives</li><li>Two-step evidence-based screening for quality assurance</li><li>Only pay for participants who truly fit your study</li></ul></div></div></div></div></div><div role="listitem" class="service-accordion w-dyn-item"><div class="service-name"><div class="text-size-large weight-medium">Focus on the insight. We own the execution.</div></div><div class="service-description"><div class="w-layout-grid service-component"><div class="service-image-wrapper"><img src="images/untitled-20design-20-23-.png" loading="lazy" alt="" class="service-image"/></div><div blocks-name="layout1_content" blocks-slot-children="ST265" id="w-node-_8a309907-dd41-8676-e504-528cd7993c04-b8105c8b" class="service-content"><div class="margin-bottom margin-small"><h2 blocks-name="heading" class="heading-style-h3">RESEARCH ACTIVATION</h2></div><div class="w-richtext"><p><strong>We handle the logistics, so you get relevant data for your research - collected in the format you need, delivered ready for insight.</strong></p><p>Multi-city fieldwork to fast-turn sprints—we bring structure, care, and clean data to every study.</p><p>‍</p><p><strong>What we handle: </strong>‍</p><p>Research Localization • Qualitative &amp; Quantitative Research • Foresight &amp; Trend Analysis • Product &amp; Design Research • Expert Panels • Facilitation &amp; Workshops • And more</p><p>‍</p><p><strong>Why it feels different:</strong></p><p>Data built for your workflow. Execution you can trust. Every project, every time.</p></div></div></div></div></div><div role="listitem" class="service-accordion w-dyn-item"><div class="service-name"><div class="text-size-large weight-medium">Spot what’s next. Turn insights into direction.</div></div><div class="service-description"><div class="w-layout-grid service-component"><div class="service-image-wrapper"><img src="images/untitled-20design-20-18-.png" loading="lazy" alt="" class="service-image"/></div><div blocks-name="layout1_content" blocks-slot-children="ST265" id="w-node-_8a309907-dd41-8676-e504-528cd7993c04-b8105c8b" class="service-content"><div class="margin-bottom margin-small"><h2 blocks-name="heading" class="heading-style-h3">STRATEGIC FUTURES</h2></div><div class="w-richtext"><p><strong>Move beyond what they say. Find what it means.</strong></p><p>Cultural context + behavioral analysis = actionable insights on what&#x27;s next.</p><p>‍</p><p><strong>Our toolkit:</strong> Societal &amp; Economic Analysis • Culture Deepdive • Consumer Behavior • Opportunity Roadmap • Competitive &amp; Industry Analysis • More</p><p>‍</p><p><strong>Why it feels different:</strong></p><p>From real-time insights to team alignment - every step is designed for action.</p></div></div></div></div></div><div role="listitem" class="service-accordion w-dyn-item"><div class="service-name"><div class="text-size-large weight-medium">From research to roadshow</div></div><div class="service-description"><div class="w-layout-grid service-component"><div class="service-image-wrapper"><img src="images/copy-20of-20untitled-20design-20-8-.png" loading="lazy" alt="" sizes="100vw" srcset="images/copy-20of-20untitled-20design-20-8-p-500.png 500w, images/copy-20of-20untitled-20design-20-8-p-800.png 800w, images/copy-20of-20untitled-20design-20-8-p-1080.png 1080w, images/copy-20of-20untitled-20design-20-8-.png 1920w" clas